pipeline{
    agent any
    tools{
        maven 'mavenjenkinsinstall'
        jdk 'jdk22'
    }
    stages{
        stage("Checkout"){
            steps{
                git branch: 'main', url: 'https://github.com/Ahtshambhurgri/BloodBankWithJavaJspHibernate'
            }
        }
        stage("Build"){
            steps{
                bat 'mvn clean install'
            }
        }
        stage("Test"){
            steps{
                bat 'mvn test'
            }
        }
        stage("Package"){
            steps{
                bat 'mvn package'
            }
        }
        
    }
}
